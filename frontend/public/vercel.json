{
  "redirects": [
    {
      "source": "/media/video/:path*",
      "destination": "https://thuongduc.dxvtech.vn/media/video/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/media/:path*",
      "destination": "https://thuongduc.dxvtech.vn/media/:path*"
    }
  ],
  "headers": [
    {
      "source": "/media/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }]
    },
    {
      "source": "/assets/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
