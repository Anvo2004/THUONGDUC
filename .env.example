# ==== vnPortal ====
# Domain thuc te cua site vnPortal, KHONG co dau / o cuoi
VNPORTAL_HOST_NAME=https://thuongduc.danang.gov.vn
VNPORTAL_LANGUAGE_ID=vi-VN
# Danh sach ArticleCatID muon theo doi, cach nhau boi dau phay. De trong = lay tat ca chuyen muc
VNPORTAL_ARTICLE_CAT_IDS=
VNPORTAL_PAGE_SIZE=10

# ==== Zalo OA ====
ZALO_APP_ID=
ZALO_APP_SECRET=
# Secret key rieng cua OA (Cai dat > lien ket ung dung), KHAC voi ZALO_APP_SECRET.
# Dung de xac thuc chu ky webhook (X-ZEvent-Signature). De trong se bo qua buoc xac thuc.
ZALO_OA_SECRET_KEY=
# Official Account Callback Url da khai bao tren Zalo Developers, vd:
# https://thuongduc.dxvtech.vn/oauth/zalo/callback
ZALO_OA_CALLBACK_URL=
# Gia tri content cua the <meta name="zalo-platform-site-verification">, lay tu
# trang "Xac thuc domain" > "Them the meta vao trang chu trang web cua ban"
ZALO_SITE_VERIFICATION_META=
# Access token / refresh token lay tu lan dang nhap OAuth dau tien (Zalo Developers)
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_REFRESH_TOKEN=
# Chi bat true sau khi da co API "Broadcast bai viet" xac nhan trong src/zalo/articleClient.js
# (hien tai broadcastArticle() se bao loi ro rang neu bat true ma chua co API nay).
# Mac dinh false = chi log ra console, khong tao/gui gi that.
ZALO_SEND_ENABLED=false
ZALO_LIST_BATCH_SIZE=5
# Anh cover mac dinh (vd logo UBND xa) dung khi tin bai/van ban khong co anh rieng -
# Zalo Article bat buoc phai co cover nen thieu bien nay se bi bo qua khong gui duoc.
ZALO_DEFAULT_COVER_URL=
# Chi dat neu endpoint mac dinh trong src/zalo/articleClient.js khong dung
# ZALO_BROADCAST_ARTICLE_ENDPOINT=https://openapi.zalo.me/v2.0/article/broadcast

# ==== Redis (Upstash) - luu access/refresh token, de trong se fallback ve file JSON cuc bo ====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==== Webhook / OAuth server ====
PORT=3000
# Thu muc phuc vu file tinh (vd: file xac thuc domain Zalo), mac dinh la ./public
# PUBLIC_DIR=

# ==== Dong bo ====
SYNC_ARTICLES_ENABLED=true
SYNC_DOCUMENTS_ENABLED=true
# Cron expression, mac dinh 10 phut/lan
SYNC_CRON_EXPRESSION=*/10 * * * *
SYNC_MAX_NEW_ITEMS_PER_RUN=20
